
<h2>Alla recept Birgit har samlat</h2>

<div class="recipe-grid">
    <%@recipes.each do |recipes| %>
            <a href="/recipes/<%= recipes['id'] %>" class="recipe-card">
                <h3><%= recipes['recipe_name'] %></h3>
                <p><%= recipes['category'] %></p>
            </a>
    <%end%>
</div>